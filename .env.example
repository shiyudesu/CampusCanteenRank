# =========================
# CampusCanteenRank local env example
# =========================

# Compose exposed ports
MYSQL_PORT=3306
REDIS_PORT=6379
API_PORT=8080
WEB_PORT=5173

# MySQL bootstrap settings
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=canteen_rank
MYSQL_USER=ccr
MYSQL_PASSWORD=ccr

# API runtime settings
LOG_LEVEL=info
JWT_SECRET=dev-only-secret-change-me-please-1234567890
MYSQL_DSN=ccr:ccr@tcp(mysql:3306)/canteen_rank?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_REFRESH_PREFIX=auth:refresh:
REDIS_RANKING_PREFIX=ranking:list:

# Web runtime settings
VITE_API_BASE_URL=http://localhost:8080
